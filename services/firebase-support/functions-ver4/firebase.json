{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [ // <--- REPLACE THIS SECTION
    {
      "source": "functions", // Point to the folder containing package.json
      "codebase": "default",
      "runtime": "nodejs18", // Or nodejs20 if preferred
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local" // Add other ignores if needed
      ],
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"] // Command to compile TypeScript
    }
  ],
  "hosting": { // ... rest of your firebase.json ...
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": { // ... your emulator settings ...
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "database": { "port": 9000 },
    "hosting": { "port": 5000 },
    "pubsub": { "port": 8085 },
    "storage": { "port": 9199 },
    "ui": { "enabled": true }
  }
}